#All the main declension systems
PATTERNS
OpenClassRegularNounDeclCanBeBare
OpenClassRegularNounDeclCantBeBare
NounDeclIrregularU
NounDeclNamesFinalI
InfinitivalDecl
RegNounFinalVowelDeclension

#suffix-based declensions
NounDeclUtjunSuffix
NounDeclUmSuffix

#Full-declension patterns

NounDeclIrregPolyWithN
NounDeclIrregularTimeVan
NounDeclOldOch
NounDeclOldFamilyOAblaut


# Dative+oblique only patterns
NounDeclOldAnForm
NounDeclFamilyNkForm
NounDeclOldRandomOAblaut
NounDeclCountry

#Irregular words
NounDeclIrregArchaicVowelReduction
NounDeclIrregReduceNer

NounDeclIrregReduce


##########################
##########################

PATTERN OpenClassRegularNounDeclCanBeBare
#This is for bucket of nouns that get similar enough inflection
# This includes regular nouns,   names, and quantifiers that are nominalized even when bare
# postpositions
#This excludes irregular U, and infinitivals
#This excludes adverbs/adjectives and participles that are nominalized when non-bare


OpenClassRegularNounDeclCanBeBareStem NSg0 CaseDefIDeclension
OpenClassRegularNounDeclCanBeBareStem RegPluralDeclension

PATTERN OpenClassRegularNounDeclCanBeBareStem
NounReg NZero NouNinflBoundary
NounReg NZero NouNinflBoundaryRed # Dir/LR optionally undergoes vowel reduction or never

NounRegPreferReduce NZero NouNinflBoundaryRed  # preferably undergoes vowel reduction
NounRegPreferReduce NZero NouNinflBoundary # Dir/LR optionally rejects vowel reduction


#GAGA GAGA!	DeclinablePostposition  NouNinflBoundary

# For names or proper nouns. Don't have the NouNInflBoundary to block glide deletion
#Country names  are in separate category because some of them take -ia suffix

NameBaseNotCountry NouNinflBoundary

#GAGA GAGA!	# quantifiers and question words are explained in the pronoun lexd
#GAGA GAGA!	Quantifier [<prn><qnt>:]
#GAGA GAGA!	QuestionWords [<prn>:] ([<rel>:]|[<itg>:])
#GAGA GAGA!	QuantifierQuestionWords [<prn><qnt>:] ([<itg>:])?
#GAGA GAGA!	StrictQuestionWords [<prn><itg>:]

PATTERN NameBaseNotCountry
NameMaleGiven [<np><ant><m>:]
NameFemaleGiven [<np><ant><f>:]

NameFamily  [<np><cog>:]
NameGivenUnclassified [<np><ant>:]
NameNotGivenCountry [<np><al>:]




PATTERN CaseDefIDeclension
#This is case/def slots where dative is -i
#Used by regular nouns
# def is optional even on bare form
(Def|Poss)?
CaseRegI_DefPoss?
AttributiveGenIDef
AttributiveInst

PATTERN CaseDefIDeclensionWithOvertcase
#This is case/def slots where dative is -i
# Used by այնպիսի nouns
# the case slot is overtly filled
CaseRegI_DefPoss
AttributiveGenIDef
AttributiveInst

PATTERN CaseDefI_OnlyGenDat
DatGenRegI (Def|Poss)?

PATTERN CaseDefUDeclension
#This is case/def slots where dative is -u
#Used by irregular nouns
# def is optional even on bare form
(Def|Poss)?
CaseRegU_DefPoss?
AttributiveGenUDef
AttributiveInst

PATTERN CaseDefUDeclensionWithOvertcase
#This is case/def slots where dative is -u
#Used by irregular nouns
# the case slot is overtly filled
CaseRegU_DefPoss
AttributiveGenUDef
AttributiveInst


PATTERN DeclUWithFixedDef
#This is case-def where dative is -u and the noun can't be bare, like an infinitival
#Hye-style means that Dat gets Def, but the other cases don't
Def|Poss
CaseRegU_DefPoss
AttributiveGenUDef
AttributiveInst

PATTERN RegNounPluralFormDeclension # plural
NPlReg CaseDefIDeclension

PATTERN RegNounPluralFormDeclensionNerOnly # plural
NPlNerOnly CaseDefIDeclension



PATTERN CaseRegIObliqueWithoutGenAndDefPoss
OblRegI  Poss?
OblRegI Def # Dir/LR
PATTERN CaseRegUObliqueWithoutGenAndDefPoss
OblRegU Poss?
OblRegU Def # Dir/LR

 
PATTERN CaseDefDatGenArchaicAn
DatGenArchaicAn (Def|Poss)? 

#GAGA GAGA!	PATTERN PluralPossessiveDeclension # plural possessive
#GAGA GAGA!	PossPl CaseRegPostPluralPoss? Def|Poss
#GAGA GAGA!	InsReg PossPl  Def|Poss

PATTERN RegPluralDeclension
# plural
RegNounPluralFormDeclension
#GAGA GAGA!	# plural possessive
#GAGA GAGA!	NSg0|NPlReg PluralPossessiveDeclension
#GAGA GAGA!	#Not doing combo of plural possessive and of attributive because weird



##########################
##########################
PATTERN OpenClassRegularNounDeclCantBeBare
#This is for bucket of words that get regular nominal inflection when not bare
# This includes  adverbs/adjectives and participles that are nominalized when non-bare
# interjctions, nubmers

OpenClassRegularNounDeclCantBeBareStem NSg0 RegNounCaseIDeclensionWithReqDef
OpenClassRegularNounDeclCantBeBareStem RegPluralDeclension

#For bookkeeping, I also have bare adjectives/adverbs here without any substantivization
AdjAdvBaseDegreed


PATTERN OpenClassRegularNounDeclCantBeBareStem
ParticipleDeclStem
AdjAdvDeclStem
#GAGA GAGA!	DeclDeclinableInterjection SubstZero NouNinflBoundary
#GAGA GAGA!	NumericalBase|CardinalFraction SubstZero  NouNinflBoundary
#GAGA GAGA!	# NumericalBase|CardinalFraction SubstZero  NouNinflBoundaryRed # I don't think these reduce Dir LR
#GAGA GAGA!	ClassicalOrdinals [<num><ord>:]  SubstZero  NouNinflBoundary
#GAGA GAGA!	AdverbialPronounDeclinable AdvZero SubstZero  NouNinflBoundary

PATTERN ParticipleDeclStem
ParticipleInflectable SubstZero NouNinflBoundary
(:Neg ParticipleInflectable Neg:) SubstZero NouNinflBoundary

PATTERN ParticipleInflectable
ResultPart
SubjectPart
ProspectivePart

PATTERN AdjAdvDeclStem
AdjAdvBaseDegreed SubstZero NouNinflBoundary
AdjAdvBaseDegreed SubstZero NouNinflBoundaryRed # Dir/LR


PATTERN AdjAdvBaseDegreed
#Adj with or without superlative prefix
AdjAdvBaseSimple
:AdjSuper AdjAdvBaseSimple AdjSuper:

PATTERN AdjAdvBaseSimple
#Bare adjectives
AdjReg AdjZero
#Bare adverbs
AdvReg AdvZero

#Derived adverbs
AdjReg AdvOren
AdjReg NouNinflBoundaryRed AdvOren # Dir/LR



PATTERN RegNounFinalVowelDeclension
# nouns with final ու which turn to վ preferably
# կատու կատուն; ձու ձուն
# distinguish between mono and poly
# include oddballs like ամուսին
NounRegMonoUFinalVBase NZero NouNinflBoundary (Def|Poss)?
NounRegPolyUFinalVBase NZero NouNinflBoundary (Def|Poss)?

#  կատվի կատուի; ձվի ձուի 
NounRegMonoUFinalVChanged NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase
NounRegMonoUFinalVBase NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

NounRegPolyUFinalVChanged NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase
NounRegPolyUFinalVBase NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

# ձվեր ձուեր
NounRegMonoUFinalVChanged NZero NouNinflBoundary RegNounPluralFormDeclension
NounRegMonoUFinalVBase NZero NouNinflBoundary RegNounPluralFormDeclension # Dir/LR

# կատուներ
NounRegPolyUFinalVBase NZero NouNinflBoundary RegNounPluralFormDeclension

# nouns where final ի turns to zero preferably
# and then dat/abl uses ու ուց
# գինի գինին
NounRegPolyIFinalZeroBase_U_Uts NZero NouNinflBoundary NSg0 (Def|Poss)?

# գինու  գինուց գինով գինում
NounRegPolyIFinalZeroChanged_U_Uts NZero NouNinflBoundary NSg0  CaseDefUDeclensionWithOvertcase

#  գինիով  գինիում, րաֆֆի-ի րաֆֆի-ից
NounRegPolyIFinalZeroBase_U_Uts NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

# գինիներ
NounRegPolyIFinalZeroBase_U_Uts NZero NouNinflBoundary  RegNounPluralFormDeclension


PATTERN RegNounCaseIDeclensionWithReqDef
#This is for singular case/def inflection where both either case or  def is required
#This is like substantivized nouns where the bare form is not interpreted as a noun
# without case
Def|Poss
# with case, with/without definite
CaseDefIDeclensionWithOvertcase

##########################
##########################


PATTERN NounDeclIrregularU
#This is for nouns and function words that take u-declension
#This don't have high vowels that can reduce
#This is a closet set of nouns
# Does not include infinitivals because infinitivals cant be bare
#Singular ձի ձիու ձիուց
UNounStemBoundary NSg0 CaseDefUDeclension
UNounStemBoundary NSg0 CaseDefIDeclension  # Dir/LR



#Plural
UNounStemBoundary RegPluralDeclension

PATTERN UNounStemBoundary
NounIrregU NZero NouNinflBoundary
#GAGA GAGA!	Number1 [<num>:]  SubstZero  NouNinflBoundary
#GAGA GAGA!	QuantifierU  [<prn><qnt>:] 


##########################
##########################

PATTERN InfinitivalDecl
#For declined infinitivals, I assume they're not pluralized
#I don't add the reduction boundary as a safety precaution
#I make bare infinitival get analyezd as just a verb
#TO DO: I don't think they can take attributive, but I put them here just to be safe

#Singular caseless definite and attributive
InfinitivalDeclStem  NSg0 DeclUWithFixedDef
#GAGA GAGA!	#Plural possessive
#GAGA GAGA!	InfinitivalDeclStem   PluralPossessiveDeclension


PATTERN InfinitivalDeclStem
Infinitival
:Neg Infinitival Neg:






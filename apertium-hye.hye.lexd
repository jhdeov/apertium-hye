#Other irregulars

PATTERN NounDeclIrregArchaicVowelReduction
# մեջ մեջի միջի
NounMonoArchaicVowelReductionBase NZero NouNinflBoundary NSg0 (Def|Poss)?
NounMonoArchaicVowelReductionReduced NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase  # Dir/LR
NounMonoArchaicVowelReductionBase NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase

# իշու
NounMonoArchaicVowelReductionReducedDativeU  NZero NouNinflBoundary NSg0 CaseDefUDeclensionWithOvertcase  # Dir/LR

# միջեր մեջեր
NounMonoArchaicVowelReductionReduced NZero NouNinflBoundary RegNounPluralFormDeclension # Dir/LR
NounMonoArchaicVowelReductionBase NZero NouNinflBoundary RegNounPluralFormDeclension 

NounMonoArchaicVowelReductionBase NZero NouNinflBoundary NSg0 AttributiveGenIDef
NounMonoArchaicVowelReductionBase NZero NouNinflBoundary NSg0 AttributiveInst   
NounMonoArchaicVowelReductionReduced NZero NouNinflBoundary NSg0 AttributiveGenIDef # Dir/LR
NounMonoArchaicVowelReductionReduced NZero NouNinflBoundary NSg0 AttributiveInst   # Dir/LR
NounMonoArchaicVowelReductionReducedDativeU  NZero NouNinflBoundary NSg0 AttributiveGenUDef # Dir/LR

PATTERN NounDeclIrregReduceNer
# for nouns like երկիր which reduce everywhere
# singular երկիր երկիրը
NounReduceBeforeNer NZero NouNinflBoundary NSg0 (Def|Poss)?
# cased երկրի երկիրի
NounReduceBeforeNer NZero NouNinflBoundaryRed NSg0 CaseDefIDeclensionWithOvertcase
NounReduceBeforeNer NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR
# plural երկրներ երկիրներ
NounReduceBeforeNer NZero NouNinflBoundaryRedForcedNer RegNounPluralFormDeclension
NounReduceBeforeNer NZero NouNinflBoundary RegNounPluralFormDeclension # Dir/LR



PATTERN NounDeclIrregPolyWithN
# these are irregular nouns which are polysyllabic but include nasal liaison
# the only example in hye are words like այնպիսի which takes -n-i and -n-ner

# singular caseless is այնպիսի, այնպիսի-ն, այնպիսի-ս
NounIrregPolyNasal NZero NouNinflBoundary NSg0 (Def|Poss)?

# singular cased takes a meaningless nasal ն before the case marker
# այնպիսի-ն-ից, այնպիսի-ն-ի-ն
NounIrregPolyNasal NZero NouNinflBoundary NSg0 NominalNasal CaseDefIDeclensionWithOvertcase

# plural takes nasal before ner, and the rest is normal
NounIrregPolyNasal NZero NouNinflBoundary  NominalNasal RegNounPluralFormDeclension



################################
################################
################################
################################
#Suffixal irregulars

PATTERN NounDeclUtjunSuffix
#paradigm of suffix ութիւն

#Singular caseless
NounUtjunSuffix NUtjunSuffix NZero NouNinflBoundary NSg0 (Def|Poss)?  

#Singular archaic case dative
NounUtjunSuffix NZero NouNinflBoundary NSg0 CaseUtjunArchaicDat (Def|Poss)? 
#Singular regular case dative
NounUtjunSuffix NUtjunSuffix NZero NouNinflBoundary NSg0 CaseDefI_OnlyGenDat   # Dir/LR

#Singular regular case oblique
NounUtjunSuffix NUtjunSuffix NZero NouNinflBoundary NSg0 CaseRegIObliqueWithoutGenAndDefPoss
#Singular archaic case oblique
NounUtjunSuffix NZero NouNinflBoundary NSg0 (CaseUtjunArchaicAbl|CaseUtjunArchaicInst) (Def|Poss)?  # Dir/LR

#Plural 
NounUtjunSuffix NUtjunSuffix  NZero NouNinflBoundary RegNounPluralFormDeclension
#Archaic -ութեանց for plural genitive/dat
NounUtjunSuffix NZero NouNinflBoundary CaseUtjunArchaicPluralDatGen (Def|Poss)?   # Dir/LR
#GAGA GAGA!	#Plural possessive (separate line for instrumental)
#GAGA GAGA!	NounUtjunSuffix NUtjunSuffix  NZero	 NouNinflBoundary NSg0|NPlReg  PluralPossessiveDeclension


#attributive, arak included թեանիս
NounUtjunSuffix  NZero NouNinflBoundary NSg0 AttributiveUtjun

PATTERN NounDeclUmSuffix
#pattern for suffix ում

#Singular caseless ծագում
NounUmSuffix NUmSuffixBase NZero NouNinflBoundary NSg0 (Def|Poss)? 
#Singular archaic case dative ծագման
NounUmSuffix NUmSuffixReduced NZero NouNinflBoundary NSg0 CaseDefDatGenArchaicAn
#Singular regular  dative case ծագումի
NounUmSuffix NUmSuffixBase NZero NouNinflBoundary NSg0 CaseDefI_OnlyGenDat   # Dir/LR
# singular regular oblique case ծագումից ծագումով
NounUmSuffix NUmSuffixBase NZero NouNinflBoundary NSg0 CaseRegIObliqueWithoutGenAndDefPoss
#Singular archaic instrument cases like ուսմանից ուսմամբ
NounUmSuffix NUmSuffixReduced NZero NouNinflBoundary NSg0 DatGenArchaicAn CaseRegIObliqueWithoutGenAndDefPoss # Dir/LR
NounUmSuffix NUmSuffixReduced NZero NouNinflBoundary NSg0 InstArchaicAmp (Def|Poss)? # Dir/LR



#Plural (already know it's polysyllabic)
NounUmSuffix NUmSuffixBase NZero NouNinflBoundary RegNounPluralFormDeclension

#GAGA GAGA!	#Plural possessive (separate line for instrumental)
#GAGA GAGA!	NounUmSuffix NUmSuffixBase  NZero NouNinflBoundary NSg0|NPlReg PluralPossessiveDeclension


#attributive,
NounUmSuffix  NZero NouNinflBoundary NSg0 AttributiveUm 
# NounUmSuffix  NZero NouNinflBoundary NPlReg AttributiveUm # already in the plural


######################
#####################
##### Archaic declensions on nouns

PATTERN NounDeclOldAnForm
#These are nouns which can take -ան in the dative
#The -an form is rather antiquated and with only a few words
#The -an then triggers arbitrary reduction
#The words should have a regular version in the regular list
# There are subcategories based on reduction EANC: գառ, գառան, գառնից vs գարուն գարնան գարունից
#GAGA GAGA!	# can also do unreduced nouns like կողմ կողման կողմանէ
#GAGA GAGA!	# Can have ամբ forms in instrumental

# base form գառ
NounOldAnFormGar NZero NouNinflBoundary NSg0  (Def|Poss)?
# regular form գառ գառեր գառի, բուռ բռի
NounOldAnFormGar NZero NouNinflBoundary NSg0  CaseDefIDeclension # Dir/LR
NounOldAnFormGar NZero NouNinflBoundary RegNounPluralFormDeclension  # Dir/LR
NounOldAnFormGar NZero NouNinflBoundaryRed NSg0  CaseDefIDeclension # Dir/LR
NounOldAnFormGar NZero NouNinflBoundaryRed RegNounPluralFormDeclension  # Dir/LR

# irregular գառան գառնից գառներ
NounOldAnFormGar NZero NouNinflBoundaryRedForcedNer NSg0 CaseDefDatGenArchaicAn
NounOldAnFormGar NZero NouNinflBoundaryRedForcedNer NSg0 NominalNasal CaseRegIObliqueWithoutGenAndDefPoss   
NounOldAnFormGar NZero NouNinflBoundaryRedForcedNer RegNounPluralFormDeclensionNerOnly 

# attributive
NounOldAnFormGar NZero NouNinflBoundaryRedForcedNer NSg0 NominalNasal AttributiveAnNoIns
NounOldAnFormGar NZero NouNinflBoundaryRedForcedNer NSg0 NominalNasal AttributiveInst 



#used to do vowel reduction phonologically, but now include in stem becauase ամռան
# base form գարուն
NounOldAnFormGarunBase NZero NouNinflBoundary NSg0  (Def|Poss)?
# regular form գարուն գարունի գարունից
NounOldAnFormGarunBase NZero NouNinflBoundary NSg0 CaseDefIDeclension  # Dir/LR
# regular plural գարուններ
NounOldAnFormGarunBase NZero NouNinflBoundary RegNounPluralFormDeclension
# irregular գարնան գարնանից, ամռան ամռանից
NounOldAnFormGarunReduced NZero NouNinflBoundary NSg0 CaseDefDatGenArchaicAn
NounOldAnFormGarunReduced NZero NouNinflBoundary NSg0 DatGenArchaicAn CaseRegIObliqueWithoutGenAndDefPoss   

# attributive
NounOldAnFormGarunReduced NZero NouNinflBoundary NSg0 AttributiveAnNoIns
NounOldAnFormGarunReduced NZero NouNinflBoundary NSg0 DatGenArchaicAn AttributiveInst


# irregular ակ that's too archaic to generate full paradigm
NounIrregArchaicEye NZero NouNinflBoundary NSg0 CaseDefDatGenArchaicAn # Dir/LR
NounIrregArchaicEye NZero NouNinflBoundary NSg0 DatGenArchaicAn CaseRegIObliqueWithoutGenAndDefPoss # Dir/LR
NounIrregArchaicEye NZero NouNinflBoundary  DatGenArchaicAn RegNounPluralFormDeclension # Dir/LR

NounIrregArchaicEye NZero NouNinflBoundary NSg0 AttributiveAnNoIns # Dir/LR

# base form աղջիկ
NounOldAnFormGirl NZero NouNinflBoundary NSg0  (Def|Poss)?
# reduced աղջկա աղջկանից
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 DatGenArchaicAnAj
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 DatGenArchaicAn CaseRegIObliqueWithoutGenAndDefPoss
# definite աղջկա-ն and possessed աղջկան-ս
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 DatGenArchaicAnAj Def
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 DatGenArchaicAn Poss
# reduced աղջկաս
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 DatGenArchaicAnAj Def|Poss # Dir/LR
# reduce dative աղջկ-ան
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 DatGenArchaicAn # Dir/LR 
# plural աղջիկներ
NounOldAnFormGirl NZero NouNinflBoundary RegNounPluralFormDeclension 

# attributive
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 AttributiveAnNoIns
NounOldAnFormGirl NZero NouNinflBoundaryRedForcedNer NSg0 DatGenArchaicAn AttributiveInst


PATTERN NounDeclOldOch
#These are nouns which can take -ոջ in the dative
#The -ոջ form is rather antiquated and with only a few words
#The -ոջ then triggers arbitrary reduction
#My cheat is to use separate reduced stems
#So this pattern   derives ընկեր ընկերոջ ընկերից քրոջ and regularized form

#Singular caseless ընկեր քույր
NounDecOldOchNominativeStem NZero NouNinflBoundary NSg0 (Def|Poss)? 
#Singular archaic case with oblique forms ընկերոջ ընկերոջից քրոջ քրոջից
NounDecOldOchObliqueStem NZero NouNinflBoundary NSg0 DatGenArchaicOch (Def|Poss)? 
NounDecOldOchObliqueStem NZero NouNinflBoundary NSg0 DatGenArchaicOch CaseRegIObliqueWithoutGenAndDefPoss
#Singular regular case
NounDecOldOchNominativeStem  NZero NouNinflBoundary NSg0 CaseDefIDeclension   # Dir/LR


#Plural 
NounDecOldOchNominativeStem  NZero NouNinflBoundary RegPluralDeclension

#GAGA GAGA!	#regularized plural possessive ընկերնիս կիներնիս
#GAGA GAGA!	NounDecOldOchNominativeStem NZero NouNinflBoundary NSg0|NPlReg  PluralPossessiveDeclension
#GAGA GAGA!	#irregular plural possessive ընկերոջնիս ընկերոջմովնիս ընկերոջովնիս կնոջնիս կնոջմովնիս կնոջոջնիս
#GAGA GAGA!	NounDecOldOchObliqueStem NZero	 NouNinflBoundary  DatGenArchaicOch PossPl CaseRegPostPluralPoss? Def|Poss  # Dir/LR
#GAGA GAGA!	NounDecOldOchObliqueStem NZero  NouNinflBoundary  DatGenArchaicOch CaseBoundaryM? InsReg PossPl  Def|Poss  # Dir/LR


#Attributive
NounDecOldOchObliqueStem NZero NouNinflBoundary NSg0 AttributiveOch



PATTERN NounDecOldOchNominativeStem
#Nominative stems ընկեր քույր
NounFamilyOchFixed 
NounFamilyOchBase
PATTERN NounDecOldOchObliqueStem
#Oblique  stems ընկեր քր
NounFamilyOchFixed 
NounFamilyOchReduced


PATTERN NounDeclOldFamilyOAblaut
#These are nouns which can take -օ- in the dative
#The -օ- form is rather antiquated and with only a few words
#The -ոջ then triggers arbitrary reduction
#My cheat is to use separate reduced stems
#So this pattern   derives հայր հոր հորից and regularized form

#Singular caseless հայր
NounFamilyOBase NZero NouNinflBoundary NSg0 (Def|Poss)? 
#Singular archaic case with oblique forms հոր հորից
NounFamilyOAblauted NZero NouNinflBoundary NSg0  DatGenArchaicEmpty  (Def|Poss)? 
NounFamilyOAblauted NZero NouNinflBoundary NSg0  DatGenArchaicEmpty CaseRegIObliqueWithoutGenAndDefPoss 
#Singular regular case հայրից
NounFamilyOBase  NZero NouNinflBoundary NSg0 CaseRegIObliqueWithoutGenAndDefPoss  # Dir/LR
#Singular հայրի
NounFamilyOBase  NZero NouNinflBoundary NSg0 CaseDefI_OnlyGenDat # Dir/LR

#Plural հայրեր 
NounFamilyOBase  NZero NouNinflBoundary RegNounPluralFormDeclension

#GAGA GAGA!	#regularized plural possessive եղբայրնիս եղբայրովնիս
#GAGA GAGA!	NounFamilyOBase NZero	 NouNinflBoundary NSg0|NPlReg  PossPl CaseRegPostPluralPoss? Def|Poss
#GAGA GAGA!	NounFamilyOBase NZero  NouNinflBoundary NSg0|NPlReg  InsReg PossPl  Def|Poss
#GAGA GAGA!	#irregular plural possessive եղբօրնիս եղբօրմովնիս եղբօրովնիս
#GAGA GAGA!	NounFamilyOAblauted NZero	 NouNinflBoundary  DatGenArchaicEmpty PossPl CaseRegPostPluralPoss? Def|Poss  # Dir/LR
#GAGA GAGA!	NounFamilyOAblauted NZero  NouNinflBoundary  DatGenArchaicEmpty CaseBoundaryM? InsReg PossPl  Def|Poss  # Dir/LR


#attributive, I don't think ablauted stem takes attributive
NounFamilyOBase NZero NouNinflBoundary NSg0 AttributiveGenIDef|AttributiveInst 


PATTERN NounDeclOldRandomOAblaut
# These are nouns which take ablaut -ա- in the dative
# տուն տան
# hye optionally take ablaut in oblique տնից տանից

#Singular caseless տուն
NounRandomOBase NZero NouNinflBoundary NSg0 (Def|Poss)? 
#Singular archaic case  տան
NounRandomOAblauted NZero NouNinflBoundary NSg0  DatGenArchaicEmpty   (Def|Poss)? 
#Singular regular case տնից
NounRandomOBase  NZero NouNinflBoundaryRed NSg0 CaseRegIObliqueWithoutGenAndDefPoss
#Singular irregular case տանից
NounRandomOAblauted  NZero NouNinflBoundary NSg0 CaseRegIObliqueWithoutGenAndDefPoss # Dir/LR
#Singular non reduced case տունից
NounRandomOBase  NZero NouNinflBoundary NSg0 CaseRegIObliqueWithoutGenAndDefPoss
#Singular տունի
NounRandomOBase  NZero NouNinflBoundary NSg0 CaseDefI_OnlyGenDat # Dir/LR


#Plural տներ
NounRandomOBase  NZero NouNinflBoundaryRed RegNounPluralFormDeclension
# unreduced
NounRandomOBase  NZero NouNinflBoundary RegNounPluralFormDeclension # Dir/LR

#GAGA GAGA!	#regularized plural possessive տուներնիս
#GAGA GAGA!	NounRandomOBase NZero  NouNinflBoundary NSg0|NPlReg  PossPl CaseRegPostPluralPoss? Def|Poss
#GAGA GAGA!	NounRandomOBase NZero  NouNinflBoundary NSg0|NPlReg  InsReg PossPl  Def|Poss


#attributive, doesnt take ablaut I think
NounRandomOBase NZero NouNinflBoundary NSg0 AttributiveGenIDef|AttributiveInst 



PATTERN NounDeclCountry
# These are country nouns which take -ոյ- reduction in dative
# անգլիա անգլիոյ պոլիս պոլսոյ -- but this is  unproductive and seen as archaic in hye
# also includes normal countries as separate list NounCountryUnreducible
# Adds toponym feature
# Some locations can be reduced like Էջմիածնի so I added optional red boundary
#Singular caseless անգլիա

NounCountryBase  				[<np><top>:] NouNinflBoundary NSg0 (Def|Poss)? 
NounCountryUnreducible  		[<np><top>:] NouNinflBoundary NSg0 (Def|Poss)? 
NounCountryHighVowelreduction 	[<np><top>:] NouNinflBoundary NSg0 (Def|Poss)? 
NounCountryIHiatusBase			[<np><top>:] NouNinflBoundary NSg0 (Def|Poss)? 
NounCountryUHiatusBase			[<np><top>:] NouNinflBoundary NSg0 (Def|Poss)? 


#Singular archaic case  անգլիոյ, must add infl boundary to get glide deletion անգլիոն
NounCountryReduced  [<np><top>:] NouNinflBoundary NSg0 DatGenArchaicOj NouNinflBoundary (Def|Poss)?   # Dir/LR
NounCountryHighVowelreduction  [<np><top>:] NouNinflBoundaryRed NSg0 DatGenArchaicOj NouNinflBoundary (Def|Poss)?   # Dir/LR

#Singular modern dative case
NounCountryBase  [<np><top>:] NouNinflBoundary NSg0 CaseDefIDeclension
NounCountryBase  [<np><top>:] NouNinflBoundaryRed NSg0 CaseDefIDeclension # Dir/LR
NounCountryUnreducible  [<np><top>:] NouNinflBoundary NSg0 CaseDefIDeclension
NounCountryUnreducible  [<np><top>:] NouNinflBoundaryRed NSg0 CaseDefIDeclension   # Dir/LR
NounCountryHighVowelreduction  [<np><top>:] NouNinflBoundaryRed NSg0 CaseDefIDeclension

# գյումրի գյումրու գյումրիի գյումրվա
NounCountryIHiatusBase   	[<np><top>:] NouNinflBoundary NSg0 CaseDefIDeclension # Dir/LR
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0  CaseDefUDeclensionWithOvertcase # գինու  գինուց գինով գինում
NounCountryIHiatusBase   	[<np><top>:]  NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR #  գինիով  գինիում, րաֆֆի-ի րաֆֆի-ից
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanDatGenSuffixVa    # Dir/LR
NounCountryIHiatusReduced  	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanDatGenSuffixVan Poss # Dir/LR 
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanDatGenSuffixVa Def  # Dir/LR 
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanDatGenSuffixVan Def # Dir/LR
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanDatGenSuffixVan CaseRegIObliqueWithoutGenAndDefPoss # Dir/LR  # Dir/LR 
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanDatGenSuffixVan # Dir/LR
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanInsVamp (Def|Poss)? # Dir/LR 
NounCountryIHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseTimeVanDatGenSuffixVa Poss # Dir/LR

# բագու բագվի բագուի
NounCountryUHiatusReduced 	[<np><top>:] NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase
NounCountryUHiatusBase  	[<np><top>:] NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR



#Plural անգլիաներ
NounCountryBase  				[<np><top>:] NouNinflBoundary RegNounPluralFormDeclension
NounCountryUnreducible  		[<np><top>:] NouNinflBoundary RegNounPluralFormDeclension
NounCountryHighVowelreduction 	[<np><top>:] NouNinflBoundary RegNounPluralFormDeclension
NounCountryIHiatusBase  		[<np><top>:] NouNinflBoundary RegNounPluralFormDeclension
NounCountryUHiatusBase 			[<np><top>:] NouNinflBoundary RegNounPluralFormDeclension


#GAGA GAGA!	#regularized plural possessive տուներնիս
#GAGA GAGA!	NounCountryBase|NounCountryUnreducible  [<np><top>:] NouNinflBoundary NSg0|NPlReg  PossPl CaseRegPostPluralPoss? Def|Poss
#GAGA GAGA!	NounCountryBase|NounCountryUnreducible  [<np><top>:] NouNinflBoundary NSg0|NPlReg  InsReg PossPl  Def|Poss


#attributive, is already in casedefI and pl decl patterns

PATTERN NounDeclNamesFinalI
# this is just for  names like Վարդուհի which take U-declension

NameFemaleGivenIFinalBase 		[<np><ant><f>:] NouNinflBoundary NSg0 (Def|Poss)? 
NameFamilyIFinalBase 			[<np><cog>:]	NouNinflBoundary NSg0 (Def|Poss)? 
# Վարդուհու Վարդուհուց Վարդուհով
NameFemaleGivenIFinalReduced	[<np><ant><f>:] NouNinflBoundary NSg0 CaseDefUDeclensionWithOvertcase
NameFamilyIFinalReduced 		[<np><cog>:] 	NouNinflBoundary NSg0 CaseDefUDeclensionWithOvertcase
# regular վարդուհիի etc
NameFemaleGivenIFinalBase		[<np><ant><f>:]	NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR
NameFamilyIFinalBase			[<np><cog>:]	NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR
# plural
NameFemaleGivenIFinalBase 		[<np><ant><f>:] NouNinflBoundary RegNounPluralFormDeclension
NameFamilyIFinalBase			[<np><cog>:] NouNinflBoundary RegNounPluralFormDeclension


PATTERN NounDeclFamilyNkForm
#These are family nouns which can take -նք in the nominative
# And նց in the genitive/dative
# and obliques in hye
#So this pattern only derives  

# Վարդանանք
NounFamilyNkForm [<np><cog>:] NNkSuffix  NouNinflBoundary   (Def|Poss)? 
# Վարդանանց
NounFamilyNkForm [<np><cog>:] NNkSuffixCaseNc NouNinflBoundary (Def|Poss)? 
# Վարդանանցից
NounFamilyNkForm [<np><cog>:] NNkSuffixCaseNc NouNinflBoundary CaseRegIObliqueWithoutGenAndDefPoss 

# regularized Վարդանանքի
NounFamilyNkForm [<np><cog>:] NNkSuffix NouNinflBoundary CaseDefIDeclension # Dir/LR
# plural
NounFamilyNkForm [<np><cog>:] NNkSuffix NouNinflBoundary RegPluralDeclension # Dir/LR

# for any name like Հովսեփ-ենք -ենց -ենցից
NameBaseNotCountry NEnkSuffix    (Def|Poss)? 
NameBaseNotCountry NEnkSuffixCaseNc    (Def|Poss)? 
NameBaseNotCountry NEnkSuffixCaseNc    CaseRegIObliqueWithoutGenAndDefPoss
NameBaseNotCountry NAnkSuffix    (Def|Poss)?  # Dir/LR
NameBaseNotCountry NAnkSuffixCaseNc    (Def|Poss)?  # Dir/LR
NameBaseNotCountry NAnkSuffixCaseNc    CaseRegIObliqueWithoutGenAndDefPoss # Dir/LR

# attributive
NameBaseNotCountry NEnkSuffixCaseNc AttributiveGenIDef|AttributiveInst
NameBaseNotCountry NEnkSuffix AttributiveGenIDef|AttributiveInst # Dir/LR
NameBaseNotCountry NAnkSuffixCaseNc AttributiveGenIDef|AttributiveInst # Dir/LR
NameBaseNotCountry NAnkSuffix AttributiveGenIDef|AttributiveInst # Dir/LR



PATTERN NounDeclIrregReduce



#For nouns which supplete or have single-lexeme paradigms
#տղա
#regular caseless and regular case տղա տղայի
NounIrregBoyBase NZero NouNinflBoundary NSg0 CaseDefIDeclension
# irregular definite տղեն տղես
NounIrregBoyReduced NZero NouNinflBoundary NSg0 NounIrregBoyRaisedVowelE Poss|Def # Dir/LR
#irregular  case տղի տղու
NounIrregBoyReduced NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR
NounIrregBoyReduced NZero NouNinflBoundary NSg0 CaseDefUDeclensionWithOvertcase # Dir/LR

#regularized plural and reguarlized case տղաների
NounIrregBoyBase NZero  NouNinflBoundary RegNounPluralFormDeclension  
# irregular plural տղեք տղեքի or տղեքների or տղերք
NounIrregBoyReduced NZero  NouNinflBoundary NounIrregBoyRaisedVowelE NPlIrregK NPlNerVacuous? CaseDefIDeclension  # Dir/LR
NounIrregBoyReduced NZero  NouNinflBoundary NounIrregBoyRaisedVowelE NPlIrregRK NPlNerVacuous? CaseDefIDeclension  # Dir/LR

#GAGA GAGA!	#regularized plural possessive տղայներնիս տղաքներնիս
#GAGA GAGA!	NounIrregBoyBase NZero	 NouNinflBoundary NSg0|(NPlIrregK? NPlReg)  PossPl CaseRegPostPluralPoss? Def|Poss  # Dir/LR
#GAGA GAGA!	NounIrregBoyBase NZero  NouNinflBoundary NSg0|(NPlIrregK? NPlReg)  InsReg PossPl  Def|Poss  # Dir/LR
#GAGA GAGA!	#irregular plural possessive տղաքնիս տղաքովնիս տղաքմովնիս
#GAGA GAGA!	NounIrregBoyBase NZero	 NouNinflBoundary NPlIrregK  PossPl CaseRegPostPluralPoss? Def|Poss
#GAGA GAGA!	NounIrregBoyBase NZero  NouNinflBoundary NPlIrregK CaseBoundaryM? InsReg PossPl  Def|Poss




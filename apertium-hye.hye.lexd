LEXICON PlDatGenIrregularKAnts
<pl><dat_gen>:կանց

# some words take a final ն before either all inflection or just vowel-initial inflection
# like մուկ(ն)-ի Or այնպիսի-ն-ով
LEXICON NominalNasal
:ն


#Definite/possessive marking
LEXICON Def
<def>:{defն}
<def>:ն # Dir/LR for pre-clitic forms
LEXICON DefNOnly
# for words that forcibly take a definite ն such as archaic սիրոյ-ն
<def>:ն

LEXICON Poss
<px1sg>:ս
#<px1sg>:ըս # Dir/LR  -- in case of typos because EANC has this rule
<px2sg>:դ
#<px2sg>:ըդ # Dir/LR  -- in case of typos because EANC has this rule


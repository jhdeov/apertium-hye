##########################
PATTERN OpenClassRegularNounDeclCantBeBare
#This is for bucket of words that get regular nominal inflection when not bare
# This includes  adverbs/adjectives and participles that are nominalized when non-bare
# interjctions, nubmers


OpenClassRegularNounDeclCantBeBareStem NSg0 RegNounCaseIDeclensionWithReqDef
OpenClassRegularNounDeclCantBeBareStem RegPluralDeclension

#For bookkeeping, I have bare adjectives/adverbs here without any substantivization
AdjAdvBaseDegreedPrefersNotReduce
AdjAdvBaseDegreedPrefersToReduce
AdjAdvBaseDegreedMonoNer
AdjAdvBaseDegreedWithAlternationsIBase
AdjAdvBaseDegreedWithAlternationsUBase

# adj քաղցրի քաղցրներ
AdjAdvMonoNerDeclStem NSg0 RegNounCaseIDeclensionWithReqDef
AdjAdvMonoNerDeclStem RegNounPluralFormDeclensionNerOnly

# make sure to duplicate in the poly final i section for adjectives like անճոռնի անճոռնու
AdjAdvDeclStemWithAlternations



PATTERN OpenClassRegularNounDeclCantBeBareStem
ParticipleDeclStem
AdjAdvDeclStem
#GAGA GAGA!	DeclDeclinableInterjection SubstZero NouNinflBoundary
#GAGA GAGA!	NumericalBase|CardinalFraction SubstZero  NouNinflBoundary
#GAGA GAGA!	# NumericalBase|CardinalFraction SubstZero  NouNinflBoundaryRed # I don't think these reduce Dir LR
#GAGA GAGA!	ClassicalOrdinals [<num><ord>:]  SubstZero  NouNinflBoundary
#GAGA GAGA!	AdverbialPronounDeclinable AdvZero SubstZero  NouNinflBoundary

PATTERN ParticipleDeclStem
ParticipleInflectable SubstZero NouNinflBoundary
(:Neg ParticipleInflectable Neg:) SubstZero NouNinflBoundary

PATTERN ParticipleInflectable
ResultPart
SubjectPart
ProspectivePart



PATTERN AdjAdvDeclStem
AdjAdvBaseDegreedPrefersNotReduce SubstZero NouNinflBoundary
AdjAdvBaseDegreedPrefersNotReduce SubstZero NouNinflBoundaryRed # Dir/LR
AdjAdvBaseDegreedPrefersToReduce SubstZero NouNinflBoundary # Dir/LR
AdjAdvBaseDegreedPrefersToReduce SubstZero NouNinflBoundaryRed 

PATTERN AdjAdvMonoNerDeclStem
AdjAdvBaseDegreedMonoNer SubstZero NouNinflBoundary
AdjAdvBaseDegreedMonoNer SubstZero NouNinflBoundaryRed # Dir/LR

PATTERN AdjAdvBaseDegreedPrefersNotReduce
#Adj with or without superlative prefix
AdjAdvBaseSimplePrefersNotReduce
:AdjSuper AdjAdvBaseSimplePrefersNotReduce AdjSuper:

PATTERN AdjAdvBaseDegreedPrefersToReduce
#Adj with or without superlative prefix
AdjAdvBaseSimplePrefersToReduce
:AdjSuper AdjAdvBaseSimplePrefersToReduce AdjSuper:

PATTERN AdjAdvBaseDegreedMonoNer
#Adj with or without superlative prefix
AdjAdvBaseMonoNer
:AdjSuper AdjAdvBaseMonoNer AdjSuper:

PATTERN AdjAdvBaseSimplePrefersToReduce
#Bare adjectives
AdjRegPrefersToReduce AdjZero
#Derived adverbs
AdjReg AdvOren # Dir/LR
AdjReg NouNinflBoundaryRed AdvOren

PATTERN AdjAdvBaseSimplePrefersNotReduce
#Bare adjectives
AdjReg AdjZero
#Bare adverbs
AdvReg AdvZero

#Derived adverbs
AdjReg AdvOren
AdjReg NouNinflBoundaryRed AdvOren # Dir/LR

PATTERN AdjAdvBaseMonoNer
#Bare adjectives քաղցր
AdjMonoWithNer AdjZero

#Derived adverbs
AdjMonoWithNer AdvOren
AdjMonoWithNer NouNinflBoundaryRed AdvOren # Dir/LR



PATTERN AdjAdvDeclStemWithAlternations
# had to duplicate adj/adv system for nouns like անճոռնի-անճոռնու

# nouns where final ի turns to zero preferably
# and then dat/abl uses ու ուց
# անճոռնին, cannot appear bare
AdjAdvBaseDegreedWithAlternationsIBase SubstZero NouNinflBoundary NSg0 (Def|Poss)

# անճոռնու  անճոռնուց անճոռնով անճոռնում
AdjAdvBaseDegreedWithAlternationsIChanged SubstZero NouNinflBoundary NSg0  CaseDefUDeclensionWithOvertcase

#  անճոռնիով  անճոռնիում, 
AdjAdvBaseDegreedWithAlternationsIBase SubstZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

# անճոռնիներ
AdjAdvBaseDegreedWithAlternationsIBase SubstZero NouNinflBoundary   RegNounPluralFormDeclension

# pattern for թթու թթվի
# had to duplicate from noun pattern


# թթուն
AdjAdvBaseDegreedWithAlternationsUBase SubstZero NouNinflBoundary NSg0 (Def|Poss)

#  թթվի թթուի
AdjAdvBaseDegreedWithAlternationsUChanged SubstZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase
AdjAdvBaseDegreedWithAlternationsUBase SubstZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

# թթուներ
AdjAdvBaseDegreedWithAlternationsUBase SubstZero NouNinflBoundary RegNounPluralFormDeclension

PATTERN AdjAdvBaseDegreedWithAlternationsIBase
#Adj with or without superlative prefix
AdjAdvBaseSimpleWithAlternationsIBase
:AdjSuper AdjAdvBaseSimpleWithAlternationsIBase AdjSuper:

PATTERN AdjAdvBaseDegreedWithAlternationsIChanged
#Adj with or without superlative prefix
AdjAdvBaseSimpleWithAlternationsIChanged
:AdjSuper AdjAdvBaseSimpleWithAlternationsIChanged AdjSuper:

PATTERN AdjAdvBaseSimpleWithAlternationsIBase
#Bare adjectives
AdjRegPolyIFinalZeroBase_U_Uts AdjZero

#Derived adverbs
AdjRegPolyIFinalZeroBase_U_Uts AdvOren # Dir/LR
AdjRegPolyIFinalZeroChanged_U_Uts  AdvOren 

PATTERN AdjAdvBaseSimpleWithAlternationsIChanged
#Bare adjectives
AdjRegPolyIFinalZeroChanged_U_Uts AdjZero
#Derived adverbs
AdjRegPolyIFinalZeroChanged_U_Uts AdvOren # Dir/LR
AdjRegPolyIFinalZeroChanged_U_Uts  AdvOren 


PATTERN AdjAdvBaseDegreedWithAlternationsUBase
#Adj with or without superlative prefix
AdjAdvBaseSimpleWithAlternationsUBase
:AdjSuper AdjAdvBaseSimpleWithAlternationsUBase AdjSuper:

PATTERN AdjAdvBaseDegreedWithAlternationsUChanged
#Adj with or without superlative prefix
AdjAdvBaseSimpleWithAlternationsUChanged
:AdjSuper AdjAdvBaseSimpleWithAlternationsUChanged AdjSuper:

PATTERN AdjAdvBaseSimpleWithAlternationsUBase
#Bare adjectives
AdjRegPolyUFinalVBase AdjZero

#Derived adverbs
AdjRegPolyUFinalVBase AdvOren # Dir/LR
AdjRegPolyUFinalVChanged  AdvOren 

PATTERN AdjAdvBaseSimpleWithAlternationsUChanged
#Bare adjectives
AdjRegPolyUFinalVChanged AdjZero
#Derived adverbs
AdjRegPolyUFinalVChanged AdvOren # Dir/LR
AdjRegPolyUFinalVChanged  AdvOren 




PATTERN RegNounFinalVowelDeclension
# nouns with final ու which turn to վ preferably
# կատու կատուն; ձու ձուն
# distinguish between mono and poly
# include oddballs like ամուսին
NounRegMonoUFinalVBase NZero NouNinflBoundary (Def|Poss)?
NounRegPolyUFinalVBase NZero NouNinflBoundary (Def|Poss)?

#  կատվի կատուի; ձվի ձուի 
NounRegMonoUFinalVChanged NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase
NounRegMonoUFinalVBase NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

NounRegPolyUFinalVChanged NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase
NounRegPolyUFinalVBase NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

# ձվեր ձուեր
NounRegMonoUFinalVChanged NZero NouNinflBoundary RegNounPluralFormDeclension
NounRegMonoUFinalVBase NZero NouNinflBoundary RegNounPluralFormDeclension # Dir/LR

# կատուներ
NounRegPolyUFinalVBase NZero NouNinflBoundary RegNounPluralFormDeclension

# nouns where final ի turns to zero preferably
# and then dat/abl uses ու ուց
# գինի գինին
NounRegPolyIFinalZeroBase_U_Uts NZero NouNinflBoundary NSg0 (Def|Poss)?

# գինու  գինուց գինով գինում
NounRegPolyIFinalZeroChanged_U_Uts NZero NouNinflBoundary NSg0  CaseDefUDeclensionWithOvertcase

#  գինիով  գինիում, րաֆֆի-ի րաֆֆի-ից
NounRegPolyIFinalZeroBase_U_Uts NZero NouNinflBoundary NSg0 CaseDefIDeclensionWithOvertcase # Dir/LR

# գինիներ
NounRegPolyIFinalZeroBase_U_Uts NZero NouNinflBoundary  RegNounPluralFormDeclension


PATTERN RegNounCaseIDeclensionWithReqDef
#This is for singular case/def inflection where both either case or  def is required
#This is like substantivized nouns where the bare form is not interpreted as a noun
# without case
Def|Poss
# with case, with/without definite
CaseDefIDeclensionWithOvertcase


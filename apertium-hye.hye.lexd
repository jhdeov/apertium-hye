PATTERN OpenClassRegularNounDeclCanBeBare
#This is for bucket of nouns that get similar enough inflection
# This includes regular nouns,   names, and quantifiers that are nominalized even when bare
# postpositions
#This excludes irregular U, and infinitivals
#This excludes adverbs/adjectives and participles that are nominalized when non-bare


OpenClassRegularNounDeclCanBeBareStem NSg0 CaseDefIDeclension
OpenClassRegularNounDeclCanBeBareStem RegPluralDeclension

PATTERN OpenClassRegularNounDeclCanBeBareStem
NounReg NZero NouNinflBoundary
NounReg NZero NouNinflBoundaryRed # Dir/LR optionally undergoes vowel reduction or never

NounRegPreferReduce NZero NouNinflBoundaryRed  # preferably undergoes vowel reduction
NounRegPreferReduce NZero NouNinflBoundary # Dir/LR optionally rejects vowel reduction


#GAGA GAGA!	DeclinablePostposition  NouNinflBoundary

# For names or proper nouns. Don't have the NouNInflBoundary to block glide deletion
#Country names  are in separate category because some of them take -ia suffix

NameBaseNotCountry NouNinflBoundary

#GAGA GAGA!	# quantifiers and question words are explained in the pronoun lexd
#GAGA GAGA!	Quantifier [<prn><qnt>:]
#GAGA GAGA!	QuestionWords [<prn>:] ([<rel>:]|[<itg>:])
#GAGA GAGA!	QuantifierQuestionWords [<prn><qnt>:] ([<itg>:])?
#GAGA GAGA!	StrictQuestionWords [<prn><itg>:]

PATTERN NameBaseNotCountry
NameMaleGiven [<np><ant><m>:]
NameFemaleGiven [<np><ant><f>:]

NameFamily  [<np><cog>:]
NameGivenUnclassified [<np><ant>:]
NameNotGivenCountry [<np><al>:]




PATTERN CaseDefIDeclension
#This is case/def slots where dative is -i
#Used by regular nouns
# def is optional even on bare form
(Def|Poss)?
CaseRegI_DefPoss?
AttributiveGenIDef
AttributiveInst

PATTERN CaseDefIDeclensionWithOvertcase
#This is case/def slots where dative is -i
# Used by այնպիսի nouns
# the case slot is overtly filled
CaseRegI_DefPoss
AttributiveGenIDef
AttributiveInst

PATTERN CaseDefI_OnlyGenDat
DatGenRegI (Def|Poss)?

PATTERN CaseDefUDeclension
#This is case/def slots where dative is -u
#Used by irregular nouns
# def is optional even on bare form
(Def|Poss)?
CaseRegU_DefPoss?
AttributiveGenUDef
AttributiveInst

PATTERN CaseDefUDeclensionWithOvertcase
#This is case/def slots where dative is -u
#Used by irregular nouns
# the case slot is overtly filled
CaseRegU_DefPoss
AttributiveGenUDef
AttributiveInst


PATTERN DeclUWithFixedDef
#This is case-def where dative is -u and the noun can't be bare, like an infinitival
#Hye-style means that Dat gets Def, but the other cases don't
Def|Poss
CaseRegU_DefPoss
AttributiveGenUDef
AttributiveInst

PATTERN RegNounPluralFormDeclension # plural
NPlReg CaseDefIDeclension

PATTERN RegNounPluralFormDeclensionNerOnly # plural
NPlNerOnly CaseDefIDeclension



PATTERN CaseRegIObliqueWithoutGenAndDefPoss
OblRegI  Poss?
OblRegI Def # Dir/LR
PATTERN CaseRegUObliqueWithoutGenAndDefPoss
OblRegU Poss?
OblRegU Def # Dir/LR

 
PATTERN CaseDefDatGenArchaicAn
DatGenArchaicAn (Def|Poss)? 

#GAGA GAGA!	PATTERN PluralPossessiveDeclension # plural possessive
#GAGA GAGA!	PossPl CaseRegPostPluralPoss? Def|Poss
#GAGA GAGA!	InsReg PossPl  Def|Poss

PATTERN RegPluralDeclension
# plural
RegNounPluralFormDeclension
#GAGA GAGA!	# plural possessive
#GAGA GAGA!	NSg0|NPlReg PluralPossessiveDeclension
#GAGA GAGA!	#Not doing combo of plural possessive and of attributive because weird




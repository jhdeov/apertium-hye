NounIrregWomanBase NZero NouNinflBoundary NSg0 AttributiveGenIDef|AttributiveInst   # Dir/LR
NounIrregWomanReducedSg NZero NouNinflBoundary NSg0 AttributiveOch
NounIrregWomanBase NZero  NouNinflBoundary NPlReg AttributiveGenIDef|AttributiveInst


# աստված աստծո աստուծո աստուծմէ
#Singular 
NounIrregGod NZero NouNinflBoundary NSg0   (Def|Poss)? 
#Regular case աստվածից ասվածով
NounIrregGod NZero NouNinflBoundary NSg0 CaseDefIDeclension # Dir/LR
# Archaic dative case  աստծո աստծու աստուծո աստուծոն , ածստոս 
#TOA: Have to variably force a boundary after ոյ to trigger glide deletion
NounIrregGodNoVowel NZero NouNinflBoundary NSg0 DatGenArchaicOj  (Def|Poss)?  #Dir/LR
NounIrregGodNoVowel NZero NouNinflBoundary NSg0 DatGenRegU  (Def|Poss)?  #Dir/LR
NounIrregGodReducedU NZero NouNinflBoundary NSg0 DatGenArchaicOj  (Def|Poss)? 
# Archaic oblique case աստծուց աստծով
NounIrregGodNoVowel NZero NouNinflBoundary NSg0 CaseRegUObliqueWithoutGenAndDefPoss
NounIrregGodReducedU NZero NouNinflBoundary NSg0 CaseRegUObliqueWithoutGenAndDefPoss  # Dir/LR

#Plural
NounIrregGod NZero  NouNinflBoundary RegNounPluralFormDeclension

#GAGA GAGA!	#Plural possessive (separate line for instrumental)
#GAGA GAGA!	NounIrregGod NZero	 NouNinflBoundary NSg0|NPlReg  PossPl CaseRegPostPluralPoss? Def|Poss
#GAGA GAGA!	NounIrregGod NZero  NouNinflBoundary NSg0|NPlReg  InsReg PossPl  Def|Poss

#don't think can form attributive irregularly
NounIrregGod NZero NouNinflBoundary NSg0 AttributiveGenIDef|AttributiveInst

# սեր սիրո հոգի հոգւոյն, սիրով մարմին մարմնո հուսո հուսով
#Regular forms are derived elsewhere by having a duplicat entry in RegNoun
#These entries here are treated as optional ones

# Archaic dative case  սեր սիրո սիրու, սիրուց, 
#Can't have  boundary after ո to block glide deletion + force ն definite
NounIrregArchaicOj NZero NouNinflBoundary NSg0 DatGenArchaicOj (DefNOnly|Poss)?   # Dir/LR
# սիրով սիրովն
NounIrregArchaicOj NZero NouNinflBoundary NSg0 CaseDefUDeclensionWithOvertcase  # Dir/LR




# for հանգստեան words
# this is optional because regular form is more common
IrregArchaicYan NZero NouNinflBoundary NSg0 DatGenArchaicYan (Def|Poss)? # Dir/LR
IrregArchaicYan NZero NouNinflBoundary NSg0 InsArchaicYamp (Def|Poss)? # Dir/LR


#For a bunch of words with frozen classical case-slots
# կայսր կայսեր
#Regular form is norm, so I only list irregular
#Regular form is derived in other declensions
IrregFrozenCase (Def|Poss)?  # Dir/LR
IrregFrozenCaseDatGenOblique (Def|Poss)? # Dir/LR
IrregFrozenCaseDatGenOblique CaseRegIObliqueWithoutGenAndDefPoss?   # Dir/LR


#GAGA GAGA!	# for words with optional syncope of non-high vowel in declined forms like բերան բերնի
#GAGA GAGA!	#I only show syncopated forms as optional. Unsyncopated should be part of regular forms
#GAGA GAGA!	NounSyncopeReduced NZero NouNinflBoundary NSg0 CaseRegI (Def|Poss)?    # Dir/LR
#GAGA GAGA!	#attributive
#GAGA GAGA!	NounSyncopeReduced NZero NouNinflBoundary NSg0 AttributiveGenIDef    # Dir/LR

#GAGA GAGA!	# For words that can reduce before plural Ներ like երկրներ
#GAGA GAGA!	# I only derive the reduction here as an optional path
#GAGA GAGA!	# The noun gets normal inflection elsewhere
#GAGA GAGA!	NounReduceBeforeNer NZero NouNinflBoundary NPlNerOnly CaseRegU? (Def|Poss)?    # Dir/LR

#GAGA GAGA!	############ Attributive
#GAGA GAGA!	#I don't think the gen-def for attributive replace def with a possessive

# for monosyllabic words which take plural ner
# հարս հարսից հարսներ
NounMonoWithNer NZero NouNinflBoundary NSg0 CaseDefIDeclension
NounMonoWithNer NZero NouNinflBoundary RegPluralDeclension # Dir/LR
NounMonoWithNer NZero NouNinflBoundary RegNounPluralFormDeclensionNerOnly



PATTERN AttributiveGenIDef
DatGenRegI  Def|Poss [+NP:] AttributiveDefinitePostInflection
PATTERN AttributiveGenUDef
DatGenRegU  Def|Poss [+NP:] AttributiveDefinitePostInflection
PATTERN AttributiveInst
InsReg  [+NP:] AttributiveInstrumentalPostInflection
PATTERN AttributiveVan
#special ones for the Van forms
[<dat_gen><def>:վան]   [+NP:] AttributiveDefinitePostInflection
[<ins>:ով]  [+NP:] AttributiveInstrumentalPostInflection
([<ins>:վանով])  [+NP:] AttributiveInstrumentalPostInflection # Dir/LR
PATTERN AttributiveUm
#special ones for the um forms
NUmSuffixReduced DatGenArchaicAn  [+NP:] AttributiveDefinitePostInflection #Dir/LR
NUmSuffixBase DatGenRegI  Def|Poss   [+NP:] AttributiveDefinitePostInflection
NUmSuffixBase InsReg [+NP:] AttributiveInstrumentalPostInflection # not sure why this was Dir/LR
PATTERN AttributiveUtjun
# archaic forms like թեանէն
CaseUtjunArchaicDat|CaseUtjunArchaicInst   [+NP:] AttributiveDefinitePostInflection #Dir/LR 
NUtjunSuffix AttributiveGenIDef|AttributiveInst

PATTERN AttributiveOch
#special ones for the och forms
DatGenArchaicOch [+NP:] AttributiveDefinitePostInflection
DatGenArchaicOch InsReg  [+NP:] AttributiveInstrumentalPostInflection 
PATTERN AttributiveKAnts
#special ones for the կանց forms
PlDatGenIrregularKAnts   [+NP:] AttributiveDefinitePostInflection
PlDatGenIrregularKAnts  InsReg [+NP:] AttributiveInstrumentalPostInflection 
#PATTERN AttributiveOts
#seems ots does not exist in hye
# PlDatGenIrregularOts   [+NP:] AttributiveDefinitePostInflection
# PlDatGenIrregularOts CaseBoundaryM InsReg   [+NP:] AttributiveInstrumentalPostInflection
# PlDatGenIrregularOts  InsReg [+NP:] AttributiveInstrumentalPostInflection # Dir/LR
PATTERN AttributiveAnNoIns
#special ones for the an forms like աղջիկ --> աղջկան-ներով, no ins because complex
DatGenArchaicAn  [+NP:] AttributiveDefinitePostInflection
DatGenArchaicAn InsReg [+NP:] AttributiveInstrumentalPostInflection # Dir/LR


PATTERN AttributiveDefinitePostInflection
#This is for declension of an attributive noun
#Pre-inflection, an attributive noun ends in genitive-definite or in instrumental
#This is for the definit-ending attributive
#It has to take some overt inflection later
NSg0 CaseRegI_DefPoss
NSg0 (Def|Poss)
NPlNerOnly CaseRegI_DefPoss?

PATTERN AttributiveInstrumentalPostInflection
#This is for the instrumental-ending attributive;
#It can't just take definite because then the same meaning as un-attributive
#It has to take some overt inflection later
NSg0 CaseRegI_DefPoss
NPlNerOnly CaseRegI_DefPoss?

#####################
####### Case patterns

PATTERN CaseRegI_DefPoss
#I incorporate Def/Poss marking here because of hye-case restriction
# i distinguish dative from genitive, and dative from the oblique cases
# obligue case is abl-ins-loc
# dative can take poss or def
# oblique can take poss but not def
#NomAccReg
DatGenRegI (Def|Poss)?
OblRegI Poss?
OblRegI Def # Dir/LR

PATTERN CaseRegU_DefPoss
#I allow the regular ի to be an optional form
#This overgeneralized for infintivals and reduced irregulars like ամսի
#I incorporate Def/Poss marking here because of hye-case restriction
#NomAccReg
DatGenRegU (Def|Poss)?
OblRegU Poss?
OblRegU Def # Dir/LR



PATTERN OblRegI
# genitive is -ի
AblReg 
InsReg 
LocReg 

PATTERN OblRegU
# genitive is -ու
# the regular oblique cases abl-ins-loc get a suffix, optional poss, but definite is banned
AblRegU 
InsReg 
LocReg


#GAGA GAGA!	PATTERN CaseRegPostPluralPoss
#GAGA GAGA!	#NomAccReg 	
#GAGA GAGA!	DatGenRegU
#GAGA GAGA!	AblReg
#GAGA GAGA!	LocReg



PATTERNS


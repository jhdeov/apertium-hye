<?xml version="1.0" encoding="UTF-8"?>
<modes>

  <mode name="hye-twol" install="no">
    <pipeline>
      <program name="hfst-strings2fst -S"/>
      <program name="hfst-compose-intersect">
        <file name=".deps/hye.twol.hfst"/>
      </program>
      <program name="hfst-fst2strings"/>
    </pipeline>
  </mode>

  <mode name="hye-morph" install="yes">
    <pipeline>
      <program name="lt-proc -w">
        <file name="hye.automorf.bin"/>
      </program>
    </pipeline>
  </mode>


  <mode name="hye-lexd" install="no">
    <pipeline>
      <program name="hfst-lookup">
        <file name=".deps/hye.LR.lexd.hfst"/>
      </program>
    </pipeline>
  </mode>

  <mode name="hye-gener" install="yes">
    <pipeline>
      <program name="lt-proc -g">
        <file name="hye.autogen.bin"/>
      </program>
    </pipeline>
  </mode>

  <mode name="hye-tagger" install="yes">
    <pipeline>
      <program name="lt-proc -w">
        <file name="hye.automorf.bin"/>
      </program>
      <program name="cg-proc -w">
        <file name="hye.rlx.bin"/>
      </program>
    </pipeline>
  </mode>

  <mode name="hye-disam" install="yes">
    <pipeline>
      <program name="lt-proc -w">
        <file name="hye.automorf.bin"/>
      </program>
      <program name="cg-conv -a"/>
      <program name="vislcg3 --trace --grammar">
        <file name="hye.rlx.bin"/>
      </program>
    </pipeline>
  </mode>

  <mode name="hye-paradigm" install="yes">
    <pipeline>
      <program name="lt-paradigm -s">
        <file name="hye.autogen.bin"/>
      </program>
    </pipeline>
  </mode>

</modes>

